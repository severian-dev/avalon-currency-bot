# Discord bot token (required)
DISCORD_TOKEN=

# Application client ID (required for command deploy)
CLIENT_ID=

# Guild ID to register guild-scoped commands against (required for command deploy)
GUILD_ID=

# Your Discord user ID. Locks down /grant and /revoke to you only.
OWNER_DISCORD_ID=

# Optional: override the SQLite file path (defaults to ./avalon-currency.db)
# DATABASE_PATH=
